      "panel-1": {
        "kind": "Panel",
        "spec": {
          "id": 1,
          "title": "Errors Across All Hosts",
          "description": "Warning-and-above from systemd journal across all Alloy-managed hosts. TTM buffer noise suppressed.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "afhby9s13z5z4c"
                      },
                      "spec": {
                        "expr": "{job=\"systemd-journal\", priority=~\"emerg|alert|crit|err|warning\"} != \"TTM\""
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "logs",
            "version": "",
            "spec": {
              "options": {
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "prettifyLogMessage": false,
                "showCommonLabels": false,
                "showLabels": true,
                "showTime": true,
                "sortOrder": "Descending",
                "wrapLogMessage": true
              },
              "fieldConfig": {
                "defaults": {},
                "overrides": []
              }
            }
          }
        }
      },
      "panel-2": {
        "kind": "Panel",
        "spec": {
          "id": 2,
          "title": "Apache Errors",
          "description": "Apache error log stream from web hosts (forum, blog2, leeannperugini, test). Notices suppressed. Empty = healthy.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "afhby9s13z5z4c"
                      },
                      "spec": {
                        "expr": "{job=\"apache\", logtype=\"error\"} != \"notice\" != \"AH00558\" != \"AH01909\""
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "logs",
            "version": "",
            "spec": {
              "options": {
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "prettifyLogMessage": false,
                "showCommonLabels": false,
                "showLabels": true,
                "showTime": true,
                "sortOrder": "Descending",
                "wrapLogMessage": true
              },
              "fieldConfig": {
                "defaults": {},
                "overrides": []
              }
            }
          }
        }
      },
      "panel-3": {
        "kind": "Panel",
        "spec": {
          "id": 3,
          "title": "Apache 4xx/5xx Responses",
          "description": "Client errors (4xx) and server errors (5xx) from Apache access logs across all web hosts.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "afhby9s13z5z4c"
                      },
                      "spec": {
                        "expr": "{job=\"apache\", logtype=\"access\"} |~ \"\\\" (4|5)[0-9]{2} \""
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "logs",
            "version": "",
            "spec": {
              "options": {
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "prettifyLogMessage": false,
                "showCommonLabels": false,
                "showLabels": true,
                "showTime": true,
                "sortOrder": "Descending",
                "wrapLogMessage": true
              },
              "fieldConfig": {
                "defaults": {},
                "overrides": []
              }
            }
          }
        }
      },
      "panel-4": {
        "kind": "Panel",
        "spec": {
          "id": 4,
          "title": "Proxmox & PBS Events",
          "description": "Warning-and-above from pve-01, pve-10 (Proxmox hosts) and pbs (Proxmox Backup Server on TrueNAS Incus). Covers pve-*, proxmox-backup-*, and pbs-related systemd units.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "afhby9s13z5z4c"
                      },
                      "spec": {
                        "expr": "{host=~\"pve-01|pve-10\", priority=~\"warning|err|crit|alert|emerg\"}",
                        "legendFormat": "PVE"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "afhby9s13z5z4c"
                      },
                      "spec": {
                        "expr": "{host=\"pbs\", priority=~\"warning|err|crit|alert|emerg\"}",
                        "legendFormat": "PBS"
                      }
                    },
                    "refId": "B",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "logs",
            "version": "",
            "spec": {
              "options": {
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "prettifyLogMessage": false,
                "showCommonLabels": false,
                "showLabels": true,
                "showTime": true,
                "sortOrder": "Descending",
                "wrapLogMessage": true
              },
              "fieldConfig": {
                "defaults": {},
                "overrides": []
              }
            }
          }
        }
      },
      "panel-5": {
        "kind": "Panel",
        "spec": {
          "id": 5,
          "title": "Service Failures",
          "description": "Systemd service failures, crashes, and abnormal exits across all Alloy-managed hosts. Empty = healthy.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "afhby9s13z5z4c"
                      },
                      "spec": {
                        "expr": "{job=\"systemd-journal\", priority=~\"emerg|alert|crit|err\"} |~ \"(?i)(failed to start|failed with result|crashed|dumped core|terminated by signal|killed|segfault)\""
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "logs",
            "version": "",
            "spec": {
              "options": {
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "prettifyLogMessage": false,
                "showCommonLabels": false,
                "showLabels": true,
                "showTime": true,
                "sortOrder": "Descending",
                "wrapLogMessage": true
              },
              "fieldConfig": {
                "defaults": {},
                "overrides": []
              }
            }
          }
        }
      },
      "panel-6": {
        "kind": "Panel",
        "spec": {
          "id": 6,
          "title": "Storage / NFS / ZFS Issues",
          "description": "NFS timeouts and hung tasks from all Alloy hosts (pve-01, pve-10, docker-int, k3s nodes). ZFS errors from backup.louielab.cc (GMKtec NUC \u2014 ZFS send/receive target). NOTE: truenas.louielab.cc uses pull-only node_exporter and does NOT push logs to Loki \u2014 check TrueNAS UI directly for storage events.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "afhby9s13z5z4c"
                      },
                      "spec": {
                        "expr": "{job=\"systemd-journal\"} |~ \"(?i)(nfs.*not responding|blocked for more than|rpc_check_timeout|server.*not responding|nfs.*timed out|mount.*failed|nfs.*error)\"",
                        "legendFormat": "NFS"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "afhby9s13z5z4c"
                      },
                      "spec": {
                        "expr": "{job=\"systemd-journal\"} |~ \"(?i)(checksum.error|read.error|write.error|degraded|faulted|unavail|resilver.started|scrub.repaired.*error|cannot.import|pool.*error|i/o.error|zpool.*DEGRADED|zpool.*FAULTED|zpool.*UNAVAIL)\" != \"zfs-auto-snap\" != \"zfs-auto-snapshot\" != \"CMD\" != \"CRON\" != \"unavailable ranges\"",
                        "legendFormat": "ZFS/backup"
                      }
                    },
                    "refId": "B",
                    "hidden": false
                  }
                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "afhby9s13z5z4c"
                      },
                      "spec": {
                        "expr": "{job=\"systemd-journal\"} |~ \"(?i)(TTM.*buffer|drm.*error|GPU.*reset|gpu.*hung)\"",
                        "legendFormat": "GPU/TTM"
                      }
                    },
                    "refId": "C",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "logs",
            "version": "",
            "spec": {
              "options": {
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "prettifyLogMessage": false,
                "showCommonLabels": false,
                "showLabels": true,
                "showTime": true,
                "sortOrder": "Descending",
                "wrapLogMessage": true
              },
              "fieldConfig": {
                "defaults": {},
                "overrides": []
              }
            }
          }
        }
      },
      "panel-7": {
        "kind": "Panel",
        "spec": {
          "id": 7,
          "title": "Log Volume by Host",
          "description": "Log ingestion rate per host over time. Spikes may indicate runaway logging or an active incident.",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "afhby9s13z5z4c"
                      },
                      "spec": {
                        "expr": "sum by (host) (count_over_time({job=\"systemd-journal\"}[5m]))",
                        "legendFormat": "{{host}}"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [],
              "queryOptions": {}
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "timeseries",
            "version": "",
            "spec": {
              "options": {
                "legend": {
                  "displayMode": "list",
                  "placement": "bottom"
                },
                "tooltip": {
                  "mode": "multi"
                }
              },
              "fieldConfig": {
                "defaults": {
                  "unit": "short",
                  "custom": {
                    "drawStyle": "line",
                    "fillOpacity": 20,
                    "lineWidth": 1,
                    "stacking": {
                      "mode": "none"
                    }
                  }
                },
                "overrides": []
              }
            }
          }
        }
      }
